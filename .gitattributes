# Normalize line endings
* text=auto

# Make sure Java files are counted
*.java linguist-detectable=true

# Mark common framework folders as vendored so their languages don't skew stats
/static/** linguist-vendored
/resources/static/** linguist-vendored
/public/** linguist-vendored
/node_modules/** linguist-vendored
/target/** linguist-vendored
/build/** linguist-vendored
/out/** linguist-vendored

# Allow frontend files to still count (not vendored individually!)
*.html linguist-detectable=true
*.css linguist-detectable=true
*.js linguist-detectable=true

# Optional: add syntax diff support
*.java diff=java
*.html diff=html
*.css diff=css
*.js diff=javascript
*.md diff=markdown
